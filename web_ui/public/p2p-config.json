{
  "$schema": "./p2p-config.schema.json",
  "version": 1,
  "transports": {
    "priority": ["nostr", "torrent", "mqtt", "ipfs"],
    "torrent": {
      "enabled": true,
      "announce": [
        "wss://tracker.openwebtorrent.com:443",
        "wss://tracker.webtorrent.dev:443"
      ]
    },
    "nostr": {
      "enabled": true,
      "relays": [
        "wss://relay.damus.io",
        "wss://nos.lol",
        "wss://nostr-pub.semisol.dev",
        "wss://nostr.oxtr.dev",
        "wss://relay.nostr.info",
        "wss://nostr.band",
        "wss://relay.snort.social",
        "wss://no.str.cr",
        "wss://nostr.mom"
      ]
    }
  },
  "signaling": {
    "resendIntervalMs": 3000,
    "resendMaxAttempts": 10
  }
}