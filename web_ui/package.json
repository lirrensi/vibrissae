{
    "name": "videochat-web-ui",
    "version": "2.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "run-p type-check \"build-only {@}\" --",
        "preview": "vite preview",
        "test:unit": "vitest",
        "test:e2e": "playwright test",
        "test:e2e:server": "node ../scripts/run-e2e.js --mode server",
        "test:e2e:p2p": "node ../scripts/run-e2e.js --mode p2p",
        "test:e2e:single": "node ../scripts/run-e2e.js --mode single",
        "test:e2e:cross-browser": "node ../scripts/run-e2e.js --mode cross-browser",
        "test:e2e:resilience": "node ../scripts/run-e2e.js --mode resilience",
        "test:e2e:mobile": "node ../scripts/run-e2e.js --mode mobile",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:debug": "playwright test --debug",
        "test:e2e:all": "node ../scripts/run-e2e.js --mode all",
        "test:e2e:quick": "node ../scripts/run-e2e.js --mode server",
        "build-only": "vite build",
        "type-check": "vue-tsc --build",
        "lint": "run-s lint:*",
        "lint:oxlint": "oxlint . --fix",
        "lint:eslint": "eslint . --fix --cache",
        "format": "oxfmt src/",
        "build:server": "cross-env BUILD_MODE=server vite build --mode server",
        "build:p2p": "cross-env BUILD_MODE=p2p vite build --mode p2p",
        "build:p2p:single": "cross-env BUILD_MODE=single VITE_BASE_URL=/vibrissae/ vite build --mode p2p",
        "prebuild": "vue-tsc --build",
        "prepare": "simple-git-hooks"
    },
    "simple-git-hooks": {
        "pre-commit": "pnpm build:p2p:single"
    },
    "dependencies": {
        "gun": "^0.2020.1241",
        "pinia": "^3.0.4",
        "trystero": "^0.22.0",
        "vue": "^3.5.29",
        "vue-i18n": "^11.2.8",
        "vue-router": "^5.0.3"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@tsconfig/node24": "^24.0.4",
        "@types/jsdom": "^28.0.0",
        "@types/node": "^25.3.3",
        "@vitejs/plugin-vue": "^6.0.4",
        "@vitest/eslint-plugin": "^1.6.9",
        "@vue/eslint-config-typescript": "^14.7.0",
        "@vue/test-utils": "^2.4.6",
        "@vue/tsconfig": "^0.8.1",
        "cross-env": "^10.1.0",
        "eslint": "^10.0.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-oxlint": "~1.50.0",
        "eslint-plugin-playwright": "^2.8.0",
        "eslint-plugin-vue": "~10.8.0",
        "jiti": "^2.6.1",
        "jsdom": "^28.1.0",
        "npm-run-all2": "^8.0.4",
        "oxfmt": "^0.35.0",
        "oxlint": "~1.50.0",
        "simple-git-hooks": "^2.13.1",
        "typescript": "~5.9.3",
        "vite": "^7.3.1",
        "vite-plugin-pwa": "^1.2.0",
        "vite-plugin-singlefile": "^2.3.0",
        "vite-plugin-vue-devtools": "^8.0.6",
        "vitest": "^4.0.18",
        "vue-tsc": "^3.2.5"
    },
    "engines": {
        "node": "^20.19.0 || >=22.12.0"
    }
}
